# 文件名: app.py

import streamlit as st
import pandas as pd
import numpy as np
import joblib

# --- 页面配置 ---
st.set_page_config(
    page_title="MAGE Prediction Model",
    page_icon="⚕️",
    layout="centered",
    initial_sidebar_state="expanded"
)

# --- 加载模型和数据范围 ---
try:
    model = joblib.load('final_mage_model.joblib')
    ranges = pd.read_csv('data_ranges.csv', index_col=0)
except FileNotFoundError:
    st.error("错误: 找不到模型文件 'final_mage_model.joblib' 或数据范围文件 'data_ranges.csv'。请先运行 'train_and_save_model.py'。")
    st.stop()

# --- 网页界面 ---
st.title('术后主要不良胃肠道事件 (MAGE) 预测模型')
st.markdown("这是一个基于逻辑回归模型构建的临床风险预测工具。")

st.sidebar.header('请输入患者的临床参数:')

# 创建输入控件
def user_input_features():
    # 为了简化，我们将用英文名作为内部变量名
    # **请确保这里的英文标签和您保存的列名一致**
    total_arch = st.sidebar.selectbox('Total Arch Replacement', ('No', 'Yes'))
    lac = st.sidebar.slider('Lactate (mmol/L)', 
                           min_value=float(ranges.loc['min', 'LAC']), 
                           max_value=float(ranges.loc['max', 'LAC']),
                           value=float(ranges.loc['min', 'LAC']),
                           step=0.1)
    cad = st.sidebar.selectbox('Coronary Artery Disease', ('No', 'Yes'))
    post_protein = st.sidebar.slider('Post-op Total Protein (g/L)', 
                                    min_value=float(ranges.loc['min', 'postTotalprotein']), 
                                    max_value=float(ranges.loc['max', 'postTotalprotein']),
                                    value=float(ranges.loc['min', 'postTotalprotein']))
    pre_pt = st.sidebar.slider('Pre-op Prothrombin Time (s)', 
                              min_value=float(ranges.loc['min', 'preprothrombintime']), 
                              max_value=float(ranges.loc['max', 'preprothrombintime']),
                              value=float(ranges.loc['min', 'preprothrombintime']))
    
    # 将输入转换为模型需要的格式
    data = {
        'Totalarchreplacementfrozenelephanttrunkimplantation': 1 if total_arch == 'Yes' else 0,
        'LAC': lac,
        'Coronaryarterydisease': 1 if cad == 'Yes' else 0,
        'postTotalprotein': post_protein,
        'preprothrombintime': pre_pt
    }
    features = pd.DataFrame(data, index=[0])
    return features

input_df = user_input_features()

# --- 显示输入 ---
st.subheader('输入的患者参数:')
st.write(input_df)

# --- 进行预测并显示结果 ---
prediction_proba = model.predict_proba(input_df)
mage_risk = prediction_proba[0, 1]

st.subheader('预测结果:')
st.write(f"该患者发生MAGE的预测风险为: **{mage_risk:.2%}**")

# 使用一个漂亮的仪表盘来显示风险
st.progress(mage_risk, text=f"风险: {mage_risk:.1%}")

st.markdown("---")
st.write("免责声明：本工具仅供研究和参考，不能替代临床决策。")

